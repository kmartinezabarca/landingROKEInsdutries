# ===========================================
# ROKE INDUSTRIES - VARIABLES DE ENTORNO
# ===========================================
# Solo se listan las variables que el código realmente lee y usa.
# Todo lo demás se eliminó por no usarse.

# ── Empresa ───────────────────────────────────────────────
# "ROKE" se fuerza a mayúsculas en el código, da igual cómo se escriba aquí.
VITE_COMPANY_NAME=ROKE Industries

# ── Contacto ──────────────────────────────────────────────
VITE_PHONE=+52 (55) 2717-5816
VITE_EMAIL=contact@rokeindustries.com
VITE_WHATSAPP=+525527175816
VITE_ADDRESS=San Jerónimo de Juárez, Guerrero.

# ── Redes sociales (se muestran en el footer solo las que tengan URL) ─────
VITE_FACEBOOK_URL=https://www.facebook.com/share/17UaeUDVo9
VITE_INSTAGRAM_URL=https://www.instagram.com/rokeindustries/
VITE_TWITTER_URL=
VITE_LINKEDIN_URL=https://www.linkedin.com/company/roke-industries/
VITE_YOUTUBE_URL=https://www.youtube.com/@rokeindustries/

# ── Mensaje de WhatsApp ───────────────────────────────────
VITE_WHATSAPP_MESSAGE=¡Hola! Me interesa conocer más sobre los servicios de ROKE Industries. ¿Podrían proporcionarme información detallada sobre sus soluciones tecnológicas?

# ── Versión de la app (opcional) ──────────────────────────
# Si se omite, se usa la versión de package.json (inyectada en build).
# VITE_APP_VERSION=1.0.0

# ── SEO ───────────────────────────────────────────────────
# URL pública del sitio (para canonical / Open Graph). Sin slash final.
VITE_SITE_URL=https://rokeindustries.com

# ── Analítica ─────────────────────────────────────────────
# Google Analytics 4. Measurement ID (G-XXXXXXXXXX). Si se deja vacío, no se
# carga analítica. Solo se activa tras el consentimiento de cookies del usuario.
VITE_GA_MEASUREMENT_ID=

# ── API / Autenticación ───────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=
# Panel del cliente (app externa) al que apunta "Acceder" y el éxito del checkout.
VITE_PANEL_URL=https://app.rokeindustries.com

# ── Servicios externos ────────────────────────────────────
# Cloudflare Turnstile (anti-bot de contacto y newsletter). Site key PÚBLICA.
# Si se deja vacía, en dev se usa la clave de prueba de Cloudflare (siempre aprueba).
# La SECRET KEY va SOLO en el backend, que verifica cf-turnstile-response contra siteverify.
VITE_TURNSTILE_SITE_KEY=
# Stripe (pago con tarjeta en checkout). Publishable key (pk_...).
VITE_STRIPE_PUBLISHABLE_KEY=
