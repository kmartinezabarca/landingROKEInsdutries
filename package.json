{
    "name": "@roke/landing",
    "description": "ROKE Industries corporate landing page built with React, Vite and TailwindCSS",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "license": "UNLICENSED",
    "author": "ROKE Industries",
    "packageManager": "pnpm@10.4.1",
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=10.0.0"
    },
    "scripts": {
        "dev": "vite",
        "start": "vite",
        "typecheck": "tsc --noEmit",
        "build": "tsc --noEmit && vite build",
        "build:staging": "tsc --noEmit && vite build --mode staging",
        "preview": "vite preview",
        "lint": "eslint src --max-warnings=20",
        "lint:fix": "eslint src --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "check": "pnpm lint && pnpm format:check",
        "clean": "rimraf dist node_modules/.vite",
        "analyze": "vite build --mode production",
        "reinstall": "rimraf node_modules pnpm-lock.yaml && pnpm install"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@radix-ui/react-accordion": "^1.2.12",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-navigation-menu": "^1.2.14",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@react-oauth/google": "^0.13.5",
        "@react-three/drei": "^10.7.7",
        "@react-three/fiber": "^9.6.1",
        "@react-three/postprocessing": "3.0.4",
        "@stripe/react-stripe-js": "^6.3.0",
        "@stripe/stripe-js": "^9.4.0",
        "@tanstack/react-query": "^5.100.10",
        "axios": "^1.16.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "framer-motion": "^12.38.0",
        "i18next": "^26.1.0",
        "lucide-react": "^0.510.0",
        "next-themes": "^0.4.6",
        "postprocessing": "6.39.1",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-hook-form": "^7.75.0",
        "react-i18next": "^17.0.7",
        "react-icons": "^5.6.0",
        "react-router-dom": "^7.15.0",
        "sileo": "^0.1.5",
        "tailwind-merge": "^3.6.0",
        "three": "^0.184.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@tailwindcss/postcss": "^4.3.0",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^25.7.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/three": "^0.184.1",
        "@vitejs/plugin-react": "^4.7.0",
        "autoprefixer": "^10.5.0",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.26",
        "globals": "^16.5.0",
        "postcss": "^8.5.14",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vite": "^6.4.2"
    }
}