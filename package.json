{
  "name": "@roke/landing",
  "description": "ROKE Industries corporate landing page built with React, Vite and TailwindCSS",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "license": "UNLICENSED",
  "author": "ROKE Industries",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "preview": "vite preview",

    "lint": "eslint src --max-warnings=20",
    "lint:fix": "eslint src --fix",

    "format": "prettier . --write",
    "format:check": "prettier . --check",

    "check": "pnpm lint && pnpm format:check",

    "clean": "rimraf dist node_modules/.vite",

    "analyze": "vite build --mode production",
    "reinstall": "rimraf node_modules pnpm-lock.yaml && pnpm install"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@radix-ui/react-accordion": "^1.2.10",
    "@radix-ui/react-dialog": "^1.1.13",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-navigation-menu": "^1.2.12",
    "@radix-ui/react-popover": "^1.1.13",
    "@radix-ui/react-select": "^2.2.4",
    "@radix-ui/react-separator": "^1.1.6",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-switch": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.6",

    "@tanstack/react-query": "^5.90.2",
    "axios": "^1.15.2",

    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.0",

    "framer-motion": "^12.15.0",

    "i18next": "^26.0.6",
    "react-i18next": "^17.0.4",

    "lucide-react": "^0.510.0",
    "react-icons": "^5.5.0",

    "next-themes": "^0.4.6",

    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",

    "react-hook-form": "^7.56.3",
    "zod": "^3.24.4",

    "sonner": "^2.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",

    "prettier": "^3.5.3",

    "tailwindcss": "^4.1.7",
    "@tailwindcss/vite": "^4.1.7",
    "@tailwindcss/postcss": "^4.1.14",
    "tw-animate-css": "^1.2.9",
    "postcss": "^8.5.6",
    "autoprefixer": "^10.4.21",

    "rimraf": "^6.0.1",

    "vite": "^6.3.5"
  }
}